		{
			"enable": true,
			"name": "QQиҒҠеӨ©й“ҫжҺҘзӣҙиҫҫ",
			"ruleType": "redirect",
			"matchType": "regexp",
			"pattern": "^https:\\/\\/(?:[^.]+\\.)?c\\.pc\\.qq\\.com\\/[^.]+\\.html\\?.*",
