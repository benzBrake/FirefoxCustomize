			"group": "йҮҚе®ҡеҗ‘",
			"isFunction": true,
			"action": "redirect",
			"to": "$1",
			"code": "// 1. и§Јжһҗ URL\nconst urlObject = new URL(detail.url);\n\n// 2. е°қиҜ•иҺ·еҸ– purl еҸӮж•°\nlet targetUrl = urlObject.searchParams.get('pfurl');\n\n// 3. еҰӮжһң purl дёҚеӯҳеңЁпјҢеҲҷиҺ·еҸ– url еҸӮж•°дҪңдёәеӨҮйҖү\nif (!targetUrl) {\n  targetUrl = urlObject.searchParams.get('url');\n}\n\n// 4. еҰӮжһңжүҫеҲ°дәҶд»»дҪ•дёҖдёӘеҸӮж•°пјҢеҶҚиҝӣиЎҢеӯ—з¬ҰдёІжӣҝжҚўе№¶иҝ”еӣһ\n//    иҝҷдёӘеҲӨж–ӯеҫҲйҮҚиҰҒпјҢеҸҜд»ҘйҳІжӯўеңЁ targetUrl дёә null ж—¶и°ғз”Ё .replace() еҜјиҮҙзЁӢеәҸжҠҘй”ҷ\nif (targetUrl) {\n  // еҰӮжһңжҸҗеҸ–еҮәзҡ„еӯ—з¬ҰдёІдёҚд»Ҙ http:// жҲ– https:// ејҖеӨҙ\n  if (!targetUrl.startsWith('http://') && !targetUrl.startsWith('https://')) {\n    targetUrl = 'https://' + targetUrl; // й»ҳи®ӨиЎҘе…… https://\n  }\n  // жё…зҗҶжң«е°ҫеӨҡдҪҷзҡ„ж–ңжқ \n  return targetUrl.replace(/\\/+$/, '/');\n}\n\n// 5. еҰӮжһңдёӨдёӘеҸӮж•°йғҪдёҚеӯҳеңЁпјҢеҸҜд»Ҙиҝ”еӣһ nullгҖҒundefined жҲ–дёҖдёӘй»ҳи®ӨеҖј\nreturn null;",
			"condition": {
				"regex": "^https:\\/\\/(?:[^.]+\\.)?c\\.pc\\.qq\\.com\\/[^.]+\\.html\\?.*"
			},
			"encoding": "utf-8"
		},
